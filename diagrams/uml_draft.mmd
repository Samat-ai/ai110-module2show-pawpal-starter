classDiagram
    class Task {
        +str description
        +str time
        +str priority
        +str frequency
        +date scheduled_date
        +bool completed
        +mark_complete()
        +next_occurrence() Task
    }

    class Pet {
        +str name
        +str species
        +list~Task~ tasks
        +add_task(task)
        +task_count() int
    }

    class Owner {
        +str name
        +add_pet(pet)
        +get_pet(pet_name) Pet
        +list_pets() list~Pet~
    }

    class Scheduler {
        +Owner owner
        +build_schedule()
        +sort_by_time(task_entries)
        +filter_tasks(...)
        +detect_conflicts(...)
        +mark_task_complete(...)
    }

    Owner "1" --> "*" Pet : manages
    Pet "1" --> "*" Task : has
    Scheduler --> Owner : uses
